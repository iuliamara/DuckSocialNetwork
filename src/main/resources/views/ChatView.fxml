<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ubb.gui.ChatController">
    <children>
        <VBox minWidth="280.0" prefWidth="280.0" spacing="10.0" style="-fx-background-color: #f5f6fa; -fx-border-color: #dcdde1; -fx-border-width: 0 1 0 0;">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Conversatii" />
                <ListView fx:id="contactListView" style="-fx-background-color: transparent; -fx-background-insets: 0;" VBox.vgrow="ALWAYS" />
            </children>
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
        </VBox>

        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-border-color: #ecf0f1; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Label fx:id="conversationTitleLabel" style="-fx-font-weight: bold; -fx-font-size: 15px;" text="Selecteaza o conversatie" />
                    </children>
                    <padding>
                        <Insets left="15.0" />
                    </padding>
                </HBox>

                <ListView fx:id="chatListView" onMouseClicked="#handleChatListClick" style="-fx-background-color: white; -fx-background-insets: 0;" VBox.vgrow="ALWAYS" />

                <VBox fx:id="inputArea" managed="false" spacing="5.0" style="-fx-background-color: #f9f9f9; -fx-background-radius: 15; -fx-border-color: #dcdde1; -fx-border-radius: 15;" visible="false">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button fx:id="cancelReplyButton" onAction="#handleCancelReply" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10;" text="X" visible="false" />
                            </children>
                            <padding>
                                <Insets left="10.0" top="5.0" />
                            </padding>
                        </HBox>

                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <TextField fx:id="messageInputField" onAction="#handleSendMessage" promptText="Scrie un mesaj..." style="-fx-background-color: transparent; -fx-padding: 10; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                                <Button fx:id="replyButton" onAction="#handleReplyMessage" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 20;" text="Reply" />
                                <Button onAction="#handleSendMessage" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Trimite" />
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="10.0" top="5.0" />
                            </padding>
                        </HBox>
                    </children>
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" />
                    </VBox.margin>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>