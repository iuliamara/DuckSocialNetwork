<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ubb.gui.FriendshipController">

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label text="Gestionare Prietenii" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <Button onAction="#handleRefreshButtonAction" text="↻ Refresh" />
    </HBox>

    <TableView fx:id="friendshipTableView" VBox.vgrow="ALWAYS" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <placeholder>
            <Label text="Nu exista prietenii de afisat." textFill="#7f8c8d"/>
        </placeholder>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 5 0 0 0;">

        <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
            <Button fx:id="prevFriendshipButton" onAction="#handlePrevFriendshipPage" text="&lt; Înapoi" />
            <Label fx:id="friendshipPageLabel" text="Pagina 1 din 1" textFill="#2c3e50">
                <font><Font name="System Bold" size="12.0"/></font>
            </Label>
            <Button fx:id="nextFriendshipButton" onAction="#handleNextFriendshipPage" text="Înainte &gt;" />
        </HBox>

        <HBox fx:id="adminActionBox" alignment="CENTER_RIGHT" spacing="10.0">
            <Button onAction="#handleAddFriendship" text="+ Adauga Prietenie"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />

            <Button onAction="#handleDeleteFriendship" text="🗑 Sterge Prietenie"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
        </HBox>

    </HBox>

</VBox>