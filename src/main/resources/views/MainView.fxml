<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainLayout" prefHeight="650.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ubb.gui.MainController">

    <left>
        <VBox spacing="5.0" style="-fx-background-color: #2c3e50;" prefWidth="220.0">
            <padding>
                <Insets top="20" right="0" bottom="20" left="0"/>
            </padding>

            <Label text="SocialDuck" textFill="WHITE">
                <font><Font name="System Bold" size="22.0"/></font>
                <padding><Insets left="15" bottom="20"/></padding>
            </Label>

            <Label fx:id="lblWelcome" text="Salut!" textFill="#bdc3c7">
                <padding><Insets left="15" bottom="10"/></padding>
                <font><Font size="14.0"/></font>
            </Label>

            <Separator style="-fx-background-color: #34495e;"/>

            <Button fx:id="btnProfile" text="👤 Profilul Meu" onAction="#goProfile"
                    maxWidth="Infinity" prefHeight="45" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;"/>

            <StackPane alignment="TOP_RIGHT">
                <Button fx:id="btnChat" text="💬 Mesaje" onAction="#goChat"
                        maxWidth="Infinity" prefHeight="45"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;"/>

                <Label fx:id="lblChatBadge" visible="false" text="0"
                       style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 1 5 1 5; -fx-font-size: 10px; -fx-font-weight: bold;">
                    <StackPane.margin>
                        <Insets top="8" right="15"/>
                    </StackPane.margin>
                </Label>
            </StackPane>

            <Button fx:id="btnSearch" text="🔍 Cautare" onAction="#goSearch"
                    maxWidth="Infinity" prefHeight="45" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;"/>

            <Button fx:id="btnRaces" text="🏁 Campionat" onAction="#goRaces"
                    maxWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;"/>

            <StackPane alignment="TOP_RIGHT">
                <Button fx:id="btnNotifications" text="🔔 Notificari" onAction="#goNotifications"
                        maxWidth="Infinity" prefHeight="45" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;"/>

                <Label fx:id="lblNotifBadge" visible="false" text="0"
                       style="-fx-background-color: #ff4757; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 1 5 1 5; -fx-font-size: 10px; -fx-font-weight: bold;">
                    <StackPane.margin>
                        <Insets top="8" right="15"/>
                    </StackPane.margin>
                </Label>
            </StackPane>

            <Region VBox.vgrow="ALWAYS" />

            <Button text="Deconectare" onAction="#handleLogout"
                    maxWidth="Infinity" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER; -fx-font-weight: bold;">
                <VBox.margin><Insets left="10" right="10"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <center>
    </center>
</BorderPane>