<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="450.0" prefWidth="700.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ubb.gui.RaceCDController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <VBox prefWidth="300.0" spacing="10.0">
            <children>
                <Label text="Adauga Eveniment Nou">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>
                <Separator />

                <Label text="Nume Cursa:" />
                <TextField fx:id="txtRaceName" promptText="ex: Grand Prix" />

                <Label text="Numar Participanti (M):" />
                <TextField fx:id="txtNumParticipants" promptText="ex: 3" />

                <Label text="Distanțe Balize (separate prin virgulă):" />
                <TextField fx:id="txtBeaconDistances" promptText="ex: 10.5, 20, 45.3" />

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleAddRace"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Salveaza Cursa" />
            </children>
        </VBox>

        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
                <Label text="Evenimente in Sistem">
                    <font>
                        <Font name="System Bold Italic" size="14.0" />
                    </font>
                </Label>
                <ListView fx:id="lstRaces" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </children>
</HBox>