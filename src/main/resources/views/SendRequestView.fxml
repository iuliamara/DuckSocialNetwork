<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ubb.gui.SendRequestController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <Label text="Gestionare Cereri de Prietenie">
        <font>
            <Font name="System Bold" size="16.0" />
        </font>
    </Label>

    <TabPane fx:id="requestTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <Tab text="Trimite Cerere Noua">
            <content>
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                    </padding>
                    <Label text="Cautare utilizator dupa username:"/>
                    <TextField fx:id="searchField" promptText="Introdu username-ul..."/>

                    <Label text="Utilizatori care nu sunt prieteni:"/>
                    <ListView fx:id="userListView" VBox.vgrow="ALWAYS"/>

                    <Button fx:id="sendRequestButton" mnemonicParsing="false" onAction="#handleSendRequest" text="Trimite Cererea"/>
                </VBox>
            </content>
        </Tab>

        <Tab text="Status Cereri Trimise">
            <content>
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                    </padding>
                    <Label text="Cererile de prietenie trimise de tine:"/>
                    <TableView fx:id="sentRequestsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="sentToColumn" text="Destinatar" prefWidth="250.0"/>
                            <TableColumn fx:id="sentStatusColumn" text="Status" prefWidth="150.0"/>
                            <TableColumn fx:id="sentDateColumn" text="Dată Trimisă" prefWidth="200.0"/>
                        </columns>
                    </TableView>
                </VBox>
            </content>
        </Tab>

        <Tab text="Prietenii Mei">
            <content>
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                    </padding>
                    <Label text="Lista prieteniilor stabilite:"/>
                    <TableView fx:id="friendsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="friendUsernameColumn" text="Username" prefWidth="300.0"/>
                            <TableColumn fx:id="friendSinceColumn" text="Prieten din..." prefWidth="200.0"/>
                        </columns>
                    </TableView>
                </VBox>
            </content>
        </Tab>

    </TabPane>
</VBox>