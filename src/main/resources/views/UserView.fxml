<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ubb.gui.UserController">

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label text="Gestionare Utilizatori" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS" /> <Label text="Filtreaza dupa:" textFill="#7f8c8d" />
        <ComboBox fx:id="userFilterComboBox" prefWidth="180.0" promptText="Selectează Tip..." />

        <Button onAction="#handleRefreshUser" text="↻ Refresh" />
    </HBox>

    <TableView fx:id="userTableView" VBox.vgrow="ALWAYS" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <placeholder>
            <Label text="Nu exista utilizatori de afisat." textFill="#7f8c8d"/>
        </placeholder>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 5 0 0 0;">

        <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
            <Button fx:id="prevUserButton" onAction="#handlePrevUserPage" text="&lt; Înapoi" />
            <Label fx:id="userPageLabel" text="Pagina 1 din 1" textFill="#2c3e50">
                <font><Font name="System Bold" size="12.0"/></font>
            </Label>
            <Button fx:id="nextUserButton" onAction="#handleNextUserPage" text="Înainte &gt;" />
        </HBox>

        <HBox fx:id="adminActionBox" alignment="CENTER_RIGHT" spacing="10.0">
            <Button onAction="#handleAddUser" text="+ Adauga User"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />

            <Button onAction="#handleDeleteUser" text="🗑 Sterge User"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
        </HBox>

    </HBox>

</VBox>